{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.d.ts", "src/WhisperTextProtocol.js"],
  "exclude": ["dist", "node_modules"]
}
